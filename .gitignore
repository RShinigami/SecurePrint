# ─────────────────────────────────────────────
#  Security — NEVER commit these
# ─────────────────────────────────────────────
database/master.key
database/*.key
*.key
*.pem
*.p12
secrets.py
config_secret.py

# ─────────────────────────────────────────────
#  Database — contains biometric data
# ─────────────────────────────────────────────
database/*.db
database/*.sqlite
database/*.sqlite3

# ─────────────────────────────────────────────
#  Biometric Data — NEVER commit fingerprint images
# ─────────────────────────────────────────────
data/real/
data/altered/
data/debug/
*.BMP
*.bmp
*.tif
*.tiff

# Keep the data folder structure but not the images
!data/.gitkeep
!data/pairs.json

